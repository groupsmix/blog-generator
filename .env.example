# AI API Keys
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gpt-4

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/blog_generator
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blog_generator
DB_USER=user
DB_PASSWORD=password

# Local storage path (alternative to DB)
LOCAL_STORAGE_PATH=./data

# Application
NODE_ENV=development
LOG_LEVEL=info
